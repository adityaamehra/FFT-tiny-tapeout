{
  "//": "──────────────────────────────────────",
  "//": "  CLOCK",
  "//": "──────────────────────────────────────",
  "CLOCK_PERIOD": 100,
  "CLOCK_PORT": "clk",

  "//": "Hold slack margin - Increase them in case you are getting hold violations.",
  "PL_RESIZER_HOLD_SLACK_MARGIN": 0.1,
  "GRT_RESIZER_HOLD_SLACK_MARGIN": 0.05,

  "//": "──────────────────────────────────────",
  "//": "  SDC CONSTRAINTS",
  "//": "──────────────────────────────────────",
  "PNR_SDC_FILE"     : "dir::constraints.sdc",
  "SIGNOFF_SDC_FILE" : "dir::constraints.sdc",

  "//": "──────────────────────────────────────",
  "//": "  SYNTHESIS",
  "//": "──────────────────────────────────────",
  "MAX_FANOUT_CONSTRAINT": 8,

  "//": "──────────────────────────────────────",
  "//": "  PLACEMENT",
  "//": "──────────────────────────────────────",
  "PL_TARGET_DENSITY_PCT": 60,
  "RUN_POST_GPL_DESIGN_REPAIR": 1,

  "//": "Slew and cap margins — replaces PL_RESIZER_MAX_SLEW/CAP_MARGIN",
  "DESIGN_REPAIR_MAX_SLEW_PCT" : 30,
  "DESIGN_REPAIR_MAX_CAP_PCT"  : 30,

  "//": "Wire length — replaces PL_RESIZER_MAX_WIRE_LENGTH",
  "DESIGN_REPAIR_MAX_WIRE_LENGTH" : 50,

  "DESIGN_REPAIR_BUFFER_INPUT_PORTS": 1,

  "//": "──────────────────────────────────────",
  "//": "  CLOCK TREE SYNTHESIS",
  "//": "──────────────────────────────────────",
  "CTS_MAX_CAP"                      : 0.2,
  "CTS_SINK_CLUSTERING_SIZE"         : 20,
  "CTS_SINK_CLUSTERING_MAX_DIAMETER" : 50,

  "//": "──────────────────────────────────────",
  "//": "  GLOBAL ROUTING / RESIZER",
  "//": "──────────────────────────────────────",

  "//": "RUN_POST_GRT_DESIGN_REPAIR replaces GLB_RESIZER_DESIGN_OPTIMIZATIONS",
  "RUN_POST_GRT_DESIGN_REPAIR" : 1,

  "//": "Replaces GLB_RESIZER_MAX_SLEW/CAP_MARGIN",
  "GRT_DESIGN_REPAIR_MAX_SLEW_PCT" : 30,
  "GRT_DESIGN_REPAIR_MAX_CAP_PCT"  : 30,

  "//": "Replaces GLB_RESIZER_MAX_WIRE_LENGTH",
  "GRT_DESIGN_REPAIR_MAX_WIRE_LENGTH" : 50,

  "//": "──────────────────────────────────────",
  "//": "  LINTING",
  "//": "──────────────────────────────────────",
  "RUN_LINTER"              : 1,
  "LINTER_INCLUDE_PDK_MODELS": 1,

  "//": "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!",
  "//": "!!! DO NOT CHANGE ANYTHING BELOW THIS POINT !!!",
  "//": "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!",

  "//": "Save some time",
  "RUN_KLAYOUT_XOR": 0,
  "RUN_KLAYOUT_DRC": 0,

  "//": "Don't put clock buffers on the outputs",
  "DESIGN_REPAIR_BUFFER_OUTPUT_PORTS": 0,

  "//": "Reduce wasted space",
  "TOP_MARGIN_MULT": 1,
  "BOTTOM_MARGIN_MULT": 1,
  "LEFT_MARGIN_MULT": 6,
  "RIGHT_MARGIN_MULT": 6,

  "//": "Absolute die size",
  "FP_SIZING": "absolute",

  "GRT_ALLOW_CONGESTION": 1,

  "FP_IO_HLENGTH": 2,
  "FP_IO_VLENGTH": 2,

  "FP_PDN_VPITCH": 38.87,

  "//": "Clock",
  "RUN_CTS": 1,

  "//": "Don't generate power rings",
  "FP_PDN_MULTILAYER": 0,

  "//": "MAGIC_DEF_LABELS may cause issues with LVS",
  "MAGIC_DEF_LABELS": 0,

  "//": "Only export pin area in LEF (without any connected nets)",
  "MAGIC_WRITE_LEF_PINONLY": 1
}